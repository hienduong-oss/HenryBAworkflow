#!/usr/bin/env bash
# Quick sync: copy changed BA-kit assets from source repo to ~/.claude/ installed location.
# Lighter than full install.sh — skips CLI install and manifest rewrite.
# Usage: ba-kit sync  (or directly: ~/.local/bin/ba-kit-sync)

set -euo pipefail

# Resolve source repo from installation manifest
STATE_DIR="${HOME}/.local/share/ba-kit/installations"
MANIFEST="${STATE_DIR}/claude.env"

if [[ ! -f "${MANIFEST}" ]]; then
  echo "No BA-kit Claude installation found. Run install.sh first." >&2
  exit 1
fi

# shellcheck source=/dev/null
source "${MANIFEST}"

ROOT_DIR="${BA_KIT_SOURCE_REPO}"
if [[ ! -d "${ROOT_DIR}" ]]; then
  echo "Source repo not found at: ${ROOT_DIR}" >&2
  exit 1
fi

TARGET_HOME="${HOME}/.claude"

sync_tree() {
  local source_dir="$1"
  local target_dir="$2"
  mkdir -p "$target_dir"
  rsync -a --delete "${source_dir}/" "$target_dir/"
}

# Sync all asset categories
for skill_dir in "${ROOT_DIR}"/skills/*; do
  if [[ -d "${skill_dir}" ]]; then
    sync_tree "${skill_dir}" "${TARGET_HOME}/skills/$(basename "${skill_dir}")"
  fi
done
sync_tree "${ROOT_DIR}/rules" "${TARGET_HOME}/rules/ba-kit"
sync_tree "${ROOT_DIR}/agents" "${TARGET_HOME}/agents"
sync_tree "${ROOT_DIR}/templates" "${TARGET_HOME}/templates"
sync_tree "${ROOT_DIR}/core" "${TARGET_HOME}/core"

# Remove stale ba-kit/ directory from old sync destination
if [[ -d "${TARGET_HOME}/ba-kit" ]]; then
  rm -rf "${TARGET_HOME}/ba-kit"
fi

echo "Synced BA-kit → ~/.claude/ from ${ROOT_DIR}"
